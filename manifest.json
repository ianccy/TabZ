{
  "manifest_version": 3,
  "name": "TabZ",
  "version": "1.0.1",
  "description": "Manage your browser tabs with collections",
  "permissions": ["tabs", "storage", "bookmarks", "identity"],
  "oauth2": {
    "client_id": "68632107320-p5tem3kmcpgc4ee98onccueo8t89bj9h.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/drive.file",
      "https://www.googleapis.com/auth/userinfo.profile",
      "https://www.googleapis.com/auth/userinfo.email"
    ]
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Open TabZ",
    "default_popup": "popup.html"
  },
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
